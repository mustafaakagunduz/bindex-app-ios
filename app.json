{
  "expo": {
    "name": "Bindex",
    "slug": "budget-app-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mustafa.bindex",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Bu uygulama kimliğinizi doğrulamak için Face ID kullanır."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090b",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.budgetapp.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "scheme": "budgetapp",
    "experiments": {
      "typedRoutes": true
    }
  }
}
